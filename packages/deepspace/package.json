{
  "name": "deepspace",
  "version": "0.1.0",
  "description": "DeepSpace SDK — build real-time collaborative apps on Cloudflare Workers",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "deepspace": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./worker": {
      "types": "./dist/worker.d.ts",
      "import": "./dist/worker.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist *.tsbuildinfo",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "better-auth": "^1.2.0",
    "jose": "^6.1.0",
    "yjs": "^13.6.0",
    "hono": "^4.6.0",
    "zustand": "^5.0.0",
    "citty": "^0.2.0",
    "@clack/prompts": "^1.2.0"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "react": { "optional": true },
    "react-dom": { "optional": true }
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241205.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0"
  },
  "keywords": [
    "deepspace",
    "cloudflare-workers",
    "durable-objects",
    "real-time",
    "collaborative",
    "sdk"
  ],
  "license": "MIT"
}
