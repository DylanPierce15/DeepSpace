{
  "name": "deepspace",
  "version": "0.1.0",
  "description": "DeepSpace SDK — build real-time collaborative apps on Cloudflare Workers",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "bin": {
    "deepspace": "../cli/dist/cli.js"
  },
  "exports": {
    ".": "./src/index.ts",
    "./worker": "./src/worker.ts"
  },
  "dependencies": {
    "@deepspace/sdk": "workspace:*",
    "@deepspace/sdk-worker": "workspace:*",
    "@deepspace/auth": "workspace:*",
    "@deepspace/types": "workspace:*",
    "@deepspace/config": "workspace:*",
    "@deepspace/cli": "workspace:*"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "react": { "optional": true },
    "react-dom": { "optional": true }
  },
  "scripts": {
    "type-check": "tsc --noEmit"
  },
  "devDependencies": {
    "typescript": "^5.7.0"
  }
}
