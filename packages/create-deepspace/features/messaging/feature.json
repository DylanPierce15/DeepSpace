    { "src": "src/components/chat-multi/AddMemberModal.tsx", "dest": "src/features/messaging/components/chat-multi/AddMemberModal.tsx" },
    { "src": "src/components/chat-multi/InvitationList.tsx", "dest": "src/features/messaging/components/chat-multi/InvitationList.tsx" }
