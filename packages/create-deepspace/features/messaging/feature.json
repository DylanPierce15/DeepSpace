    { "src": "src/ChatMultiPage.tsx", "dest": "src/features/messaging/ChatMultiPage.tsx" },
    { "src": "src/hooks/useChatChannel.ts", "dest": "src/features/messaging/hooks/useChatChannel.ts" },
    { "src": "src/hooks/useLongPress.ts", "dest": "src/features/messaging/hooks/useLongPress.ts" },
    { "src": "src/hooks/useMultiChannel.ts", "dest": "src/features/messaging/hooks/useMultiChannel.ts" },
    { "src": "src/components/chat/ChatHeader.tsx", "dest": "src/features/messaging/components/chat/ChatHeader.tsx" },
    { "src": "src/components/chat/MessageList.tsx", "dest": "src/features/messaging/components/chat/MessageList.tsx" },
    { "src": "src/components/chat/MessageInput.tsx", "dest": "src/features/messaging/components/chat/MessageInput.tsx" },
    { "src": "src/components/chat/MessageItem.tsx", "dest": "src/features/messaging/components/chat/MessageItem.tsx" },
    { "src": "src/components/chat/ThreadPanel.tsx", "dest": "src/features/messaging/components/chat/ThreadPanel.tsx" },
    { "src": "src/components/chat/UserProfilePopover.tsx", "dest": "src/features/messaging/components/chat/UserProfilePopover.tsx" },
    { "src": "src/components/chat/MessageActionSheet.tsx", "dest": "src/features/messaging/components/chat/MessageActionSheet.tsx" },
    { "src": "src/components/chat/ReactionPicker.tsx", "dest": "src/features/messaging/components/chat/ReactionPicker.tsx" },
    { "src": "src/components/chat-multi/ChannelSidebar.tsx", "dest": "src/features/messaging/components/chat-multi/ChannelSidebar.tsx" },
    { "src": "src/components/chat-multi/ChannelListItem.tsx", "dest": "src/features/messaging/components/chat-multi/ChannelListItem.tsx" },
    { "src": "src/components/chat-multi/CreateGroupModal.tsx", "dest": "src/features/messaging/components/chat-multi/CreateGroupModal.tsx" },
