{
  "name": "@deepspace/cli",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "deepspace": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsup src/cli.ts --format esm",
    "dev": "tsup src/cli.ts --format esm --watch",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@clack/prompts": "^0.8.0",
    "citty": "^0.1.0",
    "@deepspace/types": "workspace:*",
    "@deepspace/config": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.3.0",
    "typescript": "^5.7.0"
  }
}
